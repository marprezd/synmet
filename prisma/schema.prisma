// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  admin
  user
  developer
}

enum ApiKeyStatus {
  active
  revoked
  expired
}

enum SubscriptionPlan {
  free
  pro
  business
}

enum SubscriptionStatus {
  active
  canceled
  trial
  expired
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(user)

  // Relations
  accounts      Account[]
  sessions      Session[]
  apiKeys       ApiKey[]
  projects      Project[]
  subscription  Subscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  heartbeats Heartbeat[]
  activitySessions ActivitySession[]
  aiUsages AIUsage[]
  metricAggregates MetricAggregate[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// API KEYS
// ============================================================================

model ApiKey {
  id        String        @id @default(cuid())
  key       String        @unique @default(cuid())
  name      String
  status    ApiKeyStatus  @default(active)
  userId    String
  
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  expiresAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([key])
}

// ============================================================================
// PROJECTS
// ============================================================================

model Project {
  id        String  @id @default(cuid())
  name      String
  slug      String
  description String?
  
  userId    String
  
  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  heartbeats Heartbeat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, slug])
  @@index([userId])
}

// ============================================================================
// SUBSCRIPTION & BILLING
// ============================================================================

model Subscription {
  id                      String             @id @default(cuid())
  userId                  String
  plan                    SubscriptionPlan   @default(free)
  status                  SubscriptionStatus @default(active)
  renewalDate             DateTime?
  providerCustomerId      String?            // Stripe customer ID
  providerSubscriptionId  String?            // Stripe subscription ID
  trialEndsAt             DateTime?
  
  user                    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments                Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId])
  @@index([userId, status])
}

model Payment {
  id                    String         @id @default(cuid())
  subscriptionId        String
  amount                Int            // Amount in cents
  currency              String         @default("usd")
  providerPaymentId     String?        // Stripe payment intent ID
  paidAt                DateTime?
  status                PaymentStatus  @default(pending)
  
  subscription          Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, status])
}

// ============================================================================
// ACTIVITY TRACKING (HEARTBEATS)
// ============================================================================

model Heartbeat {
  id        String  @id @default(cuid())
  
  userId    String
  projectId String
  
  // File information
  file      String
  language  String?
  lines     Int?
  
  // Git information
  branch    String?
  
  // Activity metrics
  duration  Int      // in seconds
  isDebugging Boolean @default(false)
  isTesting   Boolean @default(false)
  
  timestamp DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([projectId, timestamp])
  @@index([userId, projectId, timestamp])
}

// ============================================================================
// METRICS & AGGREGATIONS
// ============================================================================

model MetricAggregate {
  id            String   @id @default(cuid())
  
  userId        String
  period        String   // e.g., "daily", "weekly", "monthly"
  interval      String   // e.g., "2024-01-01", "2024-W01", "2024-01"
  
  codingMinutes Int      @default(0)
  topLanguage   String?
  topProject    String?
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, period, interval])
  @@index([userId, period])
}

model ActivitySession {
  id        String   @id @default(cuid())
  
  userId    String
  startTime DateTime
  endTime   DateTime?
  project   String?
  language  String?
  editor    String?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@index([userId, startTime])
}

model AIUsage {
  id           String   @id @default(cuid())
  
  userId       String
  language     String?
  tool         String   // e.g., "copilot", "chatgpt", "cursor"
  minutesUsed  Int      @default(0)
  project      String?
  timestamp    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now())

  @@index([userId, timestamp])
}

// ============================================================================
// LEGACY METRICS (TO BE MIGRATED)
// ============================================================================

model DailyMetrics {
  id          String   @id @default(cuid())
  
  userId      String
  projectId   String?
  date        DateTime
  
  totalDuration      Int // in seconds
  heartbeatCount     Int
  languagesUsed      String[] // JSON array of languages
  filesModified      Int
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, projectId, date])
  @@index([userId, date])
  @@index([projectId, date])
}